<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Grand Azure Hotel</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Source+Sans+3:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <nav class="navbar">
        <div class="nav-container">
            <a class="nav-brand" href="/">
                <i class="fas fa-hotel"></i>
                <span>Grand Azure</span>
            </a>
            <div class="nav-links">
                <a href="/Rooms" class="nav-link"><i class="fas fa-door-open"></i> Rooms</a>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a href="/Booking/MyBookings" class="nav-link"><i class="fas fa-calendar-check"></i> My Bookings</a>
                    <a href="/Tickets" class="nav-link"><i class="fas fa-headset"></i> Support</a>
                    @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
                    {
                        <a href="/Admin/Rooms" class="nav-link nav-admin"><i class="fas fa-cog"></i> Admin</a>
                    }
                    @if (User.IsInRole("Admin"))
                    {
                        <a href="/Admin/Hotels" class="nav-link nav-admin"><i class="fas fa-hotel"></i> Hotels</a>
                    }
                    <div class="nav-user">
                        <span class="nav-user-name">
                            <i class="fas fa-user-circle"></i>
                            @User.Identity?.Name
                        </span>
                        <form method="post" asp-page="/Account/Logout" class="nav-logout-form">
                            <button type="submit" class="nav-link btn-logout"><i class="fas fa-sign-out-alt"></i> Logout</button>
                        </form>
                    </div>
                }
                else
                {
                    <a href="/Account/Login" class="nav-link"><i class="fas fa-sign-in-alt"></i> Login</a>
                    <a href="/Account/Register" class="nav-link btn-register"><i class="fas fa-user-plus"></i> Register</a>
                }
            </div>
        </div>
    </nav>

    <main class="main-content">
        @RenderBody()
    </main>

    <!-- Floating AI Chatbot -->
    <div class="ai-chat-floating" id="ai-chat-floating">
        <div class="ai-chat-window" id="ai-chat-window">
            <div class="ai-chat-header">
                <h5><i class="fas fa-robot"></i> AI Concierge</h5>
                <button class="ai-chat-close" onclick="toggleAiChat()"><i class="fas fa-times"></i></button>
            </div>
            <div class="ai-chat-messages" id="floating-chat-messages">
                <div class="ai-message ai-bubble markdown-body">
                    <p>Hello! I'm your <strong>Grand Azure AI Concierge</strong>. How can I help you today?</p>
                </div>
            </div>
            <div class="ai-chat-footer">
                <input type="text" id="floating-chat-input" placeholder="Type your message..." />
                <button onclick="sendFloatingAiMessage()"><i class="fas fa-paper-plane"></i></button>
            </div>
        </div>
        <button class="ai-chat-toggle" onclick="toggleAiChat()" title="Talk to AI Concierge">
            <i class="fas fa-comment-dots"></i>
        </button>
    </div>

    <footer class="footer">
        <div class="footer-container">
            <div class="footer-brand">
                <h3><i class="fas fa-hotel"></i> Grand Azure Hotel</h3>
                <p>Where luxury meets comfort</p>
            </div>
            <div class="footer-links">
                <a href="/Rooms">Rooms & Suites</a>
                <a href="/Reviews">Guest Reviews</a>
                <a href="/Tickets">Support</a>
            </div>
            <div class="footer-contact">
                <p><i class="fas fa-phone"></i> +84 123 456 789</p>
                <p><i class="fas fa-envelope"></i> info@grandazure.com</p>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; 2026 Grand Azure Hotel. All rights reserved.</p>
        </div>
    </footer>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <script>
        function toggleAiChat() {
            const window = document.getElementById('ai-chat-window');
            window.classList.toggle('active');
            if (window.classList.contains('active')) {
                document.getElementById('floating-chat-input').focus();
            }
        }

        async function sendFloatingAiMessage() {
            const input = document.getElementById('floating-chat-input');
            const message = input.value.trim();
            if (!message) return;

            const msgs = document.getElementById('floating-chat-messages');
            msgs.innerHTML += `<div class="ai-message user-bubble">${message}</div>`;
            input.value = '';
            input.disabled = true;

            const thinkingId = 'thinking-' + Date.now();
            msgs.innerHTML += `<div id="${thinkingId}" class="ai-message ai-bubble thinking">AI is thinking...</div>`;
            msgs.scrollTop = msgs.scrollHeight;

            try {
                // Determine roomId if on a detail page
                let roomId = null;
                const urlParams = new URLSearchParams(window.location.search);
                if (window.location.pathname.toLowerCase().includes('/rooms/detail')) {
                    roomId = urlParams.get('id');
                }

                const endpoint = roomId 
                    ? `/api/ai/answer?question=${encodeURIComponent(message)}&roomId=${roomId}`
                    : `/api/ai/answer?question=${encodeURIComponent(message)}`;

                const res = await fetch(endpoint);
                const data = await res.json();

                const thinkingBubble = document.getElementById(thinkingId);
                if (thinkingBubble) thinkingBubble.remove();

                const formattedAnswer = marked.parse(data.answer || 'I apologize, I could not generate a response.');
                msgs.innerHTML += `<div class="ai-message ai-bubble markdown-body">${formattedAnswer}</div>`;

                // Handle AI actions
                if (data.action === 'REDIRECT_BOOKING') {
                    const roomId = data.actionData || '0';
                    setTimeout(() => {
                        window.location.href = `/Booking/Create?roomId=${roomId}`;
                    }, 2000); // Redirect after 2 seconds so the user can read the message
                }
                if (data.action === 'REDIRECT_PAYMENT') {
                    // actionData may be roomId or a JSON string { roomId, checkIn, checkOut, guests }
                    let roomIdForPay = null, checkIn = null, checkOut = null, guests = null;
                    try {
                        const parsed = typeof data.actionData === 'string' ? JSON.parse(data.actionData) : data.actionData;
                        roomIdForPay = parsed?.roomId ?? parsed;
                        checkIn = parsed?.checkIn ?? null;
                        checkOut = parsed?.checkOut ?? null;
                        guests = parsed?.guests ?? null;
                    } catch {
                        roomIdForPay = data.actionData || null;
                    }
                    if (!roomIdForPay) return;
                    const form = new FormData();
                    form.append('roomId', roomIdForPay);
                    if (checkIn) form.append('checkIn', checkIn);
                    if (checkOut) form.append('checkOut', checkOut);
                    if (guests) form.append('guests', guests);
                    const resp = await fetch('/api/ai/quick-book', { method: 'POST', body: form });
                    const jb = await resp.json();
                    if (resp.ok && jb.paymentUrl) {
                        setTimeout(() => { window.location.href = jb.paymentUrl; }, 1500);
                    } else {
                        msgs.innerHTML += `<div class="ai-message ai-bubble error">Unable to create booking automatically: ${jb.error || 'Unknown error'}</div>`;
                    }
                }
            } catch (err) {
                const thinkingBubble = document.getElementById(thinkingId);
                if (thinkingBubble) thinkingBubble.remove();
                msgs.innerHTML += `<div class="ai-message ai-bubble error">Sorry, I'm having trouble connecting right now.</div>`;
            } finally {
                input.disabled = false;
                input.focus();
                msgs.scrollTop = msgs.scrollHeight;
            }
        }

        document.getElementById('floating-chat-input')?.addEventListener('keydown', e => {
            if (e.key === 'Enter') sendFloatingAiMessage();
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
