@page
@model HotelBooking.Web.Pages.Reports.FinancialModel
@using HotelBooking.Business.DTOs
@{
    ViewData["Title"] = "Financial Dashboard";
}

<div class="report-container">
    <div class="report-header">
        <h1><i class="fas fa-chart-line"></i> Financial Dashboard</h1>
        <div class="report-filters">
            <form method="get" class="filter-form">
                <div class="filter-group">
                    <label>Start Date</label>
                    <input type="date" asp-for="StartDate" class="form-control" />
                </div>
                <div class="filter-group">
                    <label>End Date</label>
                    <input type="date" asp-for="EndDate" class="form-control" />
                </div>
                @if (User.IsInRole("Admin"))
                {
                    <div class="filter-group">
                        <label>Hotel</label>
                        <select asp-for="HotelId" class="form-control">
                            <option value="">All Hotels</option>
                            @foreach (var hotel in Model.AvailableHotels)
                            {
                                <option value="@hotel.Id">@hotel.Name</option>
                            }
                        </select>
                    </div>
                }
                <div class="filter-actions">
                    <button type="submit" class="btn btn-primary"><i class="fas fa-filter"></i> Apply</button>
                    <a asp-page-handler="ExportCsv" asp-route-StartDate="@Model.StartDate.ToString("yyyy-MM-dd")" asp-route-EndDate="@Model.EndDate.ToString("yyyy-MM-dd")" asp-route-HotelId="@Model.HotelId" class="btn btn-success">
                        <i class="fas fa-file-csv"></i> Export CSV
                    </a>
                </div>
            </form>
        </div>
    </div>

    @if (Model.Report != null)
    {
        <div class="metrics-grid">
            <div class="metric-card">
                <div class="metric-icon revenue"><i class="fas fa-dollar-sign"></i></div>
                <div class="metric-info">
                    <span class="metric-label">Total Revenue</span>
                    <span class="metric-value">@Model.Report.TotalRevenue.ToString("C0")</span>
                </div>
            </div>
            <div class="metric-card">
                <div class="metric-icon bookings"><i class="fas fa-calendar-check"></i></div>
                <div class="metric-info">
                    <span class="metric-label">Total Bookings</span>
                    <span class="metric-value">@Model.Report.TotalBookings</span>
                </div>
            </div>
            <div class="metric-card">
                <div class="metric-icon extra"><i class="fas fa-plus-circle"></i></div>
                <div class="metric-info">
                    <span class="metric-label">Extra Charges</span>
                    <span class="metric-value">@Model.Report.ExtraChargeRevenue.ToString("C0")</span>
                </div>
            </div>
            <div class="metric-card">
                <div class="metric-icon refunds"><i class="fas fa-undo"></i></div>
                <div class="metric-info">
                    <span class="metric-label">Refunds Issued</span>
                    <span class="metric-value">@Model.Report.RefundAmount.ToString("C0")</span>
                </div>
            </div>
        </div>

        <div class="report-content">
            <div class="chart-section">
                <h3>Revenue Over Time</h3>
                <canvas id="revenueChart" height="100"></canvas>
            </div>

            <div class="details-section">
                @if (User.IsInRole("Admin") && !Model.HotelId.HasValue)
                {
                    <div class="hotel-breakdown">
                        <h3>Breakdown by Hotel</h3>
                        <div class="table-responsive">
                            <table class="table">
                                <thead>
                                    <tr>
                                        <th>Hotel Name</th>
                                        <th>Bookings</th>
                                        <th>Revenue</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var hotel in Model.Report.HotelReports)
                                    {
                                        <tr>
                                            <td>@hotel.HotelName</td>
                                            <td>@hotel.BookingCount</td>
                                            <td>@hotel.TotalRevenue.ToString("C0")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }

                <div class="daily-table">
                    <h3>Daily Details</h3>
                    <div class="table-responsive">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Revenue</th>
                                    <th>Bookings</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var day in Model.Report.DailyRevenues.OrderByDescending(d => d.Date))
                                {
                                    <tr>
                                        <td>@day.Date.ToShortDateString()</td>
                                        <td>@day.Revenue.ToString("C0")</td>
                                        <td>@day.BookingCount</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="empty-state">
            <i class="fas fa-chart-bar"></i>
            <p>No data found for the selected range.</p>
        </div>
    }
</div>

@section Styles {
    <style>
        .report-container { padding: 2rem; max-width: 1200px; margin: 0 auto; }
        .report-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem; }
        .filter-form { display: flex; gap: 1rem; align-items: flex-end; flex-wrap: wrap; }
        .filter-group { display: flex; flex-direction: column; gap: 0.25rem; }
        .filter-group label { font-size: 0.8rem; color: #666; font-weight: 600; }
        .metrics-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.5rem; margin-bottom: 2rem; }
        .metric-card { background: white; padding: 1.5rem; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); display: flex; align-items: center; gap: 1rem; border: 1px solid #eee; }
        .metric-icon { width: 48px; height: 48px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.25rem; }
        .metric-icon.revenue { background: #e3f2fd; color: #1976d2; }
        .metric-icon.bookings { background: #f1f8e9; color: #689f38; }
        .metric-icon.extra { background: #fff3e0; color: #f57c00; }
        .metric-icon.refunds { background: #ffebee; color: #d32f2f; }
        .metric-value { display: block; font-size: 1.5rem; font-weight: 700; color: #333; }
        .metric-label { font-size: 0.9rem; color: #666; }
        .report-content { display: flex; flex-direction: column; gap: 2rem; }
        .chart-section { background: white; padding: 1.5rem; border-radius: 12px; border: 1px solid #eee; box-shadow: 0 4px 6px rgba(0,0,0,0.05); }
        .details-section { display: grid; grid-template-columns: repeat(auto-fit, minmax(400px, 1fr)); gap: 2rem; }
        .hotel-breakdown, .daily-table { background: white; padding: 1.5rem; border-radius: 12px; border: 1px solid #eee; }
        .empty-state { text-align: center; padding: 4rem; color: #999; }
        .empty-state i { font-size: 3rem; margin-bottom: 1rem; }
    </style>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const ctx = document.getElementById('revenueChart');
            if (!ctx) return;

            const dailyData = @Html.Raw(Json.Serialize(Model.Report?.DailyRevenues ?? new List<DailyRevenueDto>()));
            
            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: dailyData.map(d => new Date(d.date).toLocaleDateString()),
                    datasets: [{
                        label: 'Revenue',
                        data: dailyData.map(d => d.revenue),
                        borderColor: '#1976d2',
                        backgroundColor: 'rgba(25, 118, 210, 0.1)',
                        fill: true,
                        tension: 0.4
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: { position: 'bottom' }
                    },
                    scales: {
                        y: { beginAtZero: true }
                    }
                }
            });
        });
    </script>
}
