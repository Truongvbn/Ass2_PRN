@page
@model HotelBooking.Web.Pages.Tickets.CreateModel
@{
    ViewData["Title"] = "New Support Ticket";
}

<div class="page-container">
    <div class="page-header">
        <a href="/Tickets" class="back-link"><i class="fas fa-arrow-left"></i> My Tickets</a>
        <h1><i class="fas fa-plus-circle"></i> New Support Ticket</h1>
    </div>

    <div class="form-card">
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger"><i class="fas fa-exclamation-circle"></i> @Model.ErrorMessage</div>
        }

        <form method="post">
            <div class="form-group">
                <label asp-for="Input.Category"><i class="fas fa-tag"></i> Category</label>
                <select asp-for="Input.Category" class="form-control" required>
                    <option value="">Select a category...</option>
                    <option value="Room">Room Issue</option>
                    <option value="Service">Service</option>
                    <option value="Payment">Payment</option>
                    <option value="Other">Other</option>
                </select>
                <span asp-validation-for="Input.Category" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Input.Subject"><i class="fas fa-heading"></i> Subject</label>
                <input asp-for="Input.Subject" class="form-control" placeholder="Brief summary of your issue..." />
                <span asp-validation-for="Input.Subject" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Input.Description"><i class="fas fa-align-left"></i> Description</label>
                <textarea asp-for="Input.Description" class="form-control" rows="6"
                          placeholder="Please describe your issue in detail..."></textarea>
                <span asp-validation-for="Input.Description" class="field-error"></span>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-paper-plane"></i> Submit Ticket
                </button>
                <a href="/Tickets" class="btn btn-outline">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
