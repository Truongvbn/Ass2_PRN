@page
@model HotelBooking.Web.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Create Account";
}

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-brand">
            <i class="fas fa-hotel"></i>
            <h1>Grand Azure</h1>
            <p>Create your account and experience luxury.</p>
        </div>

        <form method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="form-group">
                <label asp-for="Input.FullName">Full Name</label>
                <div class="input-icon">
                    <i class="fas fa-user"></i>
                    <input asp-for="Input.FullName" class="form-control" placeholder="John Smith" />
                </div>
                <span asp-validation-for="Input.FullName" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Input.Email">Email Address</label>
                <div class="input-icon">
                    <i class="fas fa-envelope"></i>
                    <input asp-for="Input.Email" class="form-control" placeholder="your@email.com" />
                </div>
                <span asp-validation-for="Input.Email" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Input.PhoneNumber">Phone Number</label>
                <div class="input-icon">
                    <i class="fas fa-phone"></i>
                    <input asp-for="Input.PhoneNumber" class="form-control" placeholder="+84 123 456 789" />
                </div>
                <span asp-validation-for="Input.PhoneNumber" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Input.Password">Password</label>
                <div class="input-icon">
                    <i class="fas fa-lock"></i>
                    <input asp-for="Input.Password" type="password" class="form-control" placeholder="Min 6 chars, 1 uppercase, 1 digit, 1 special" />
                </div>
                <span asp-validation-for="Input.Password" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Input.ConfirmPassword">Confirm Password</label>
                <div class="input-icon">
                    <i class="fas fa-lock"></i>
                    <input asp-for="Input.ConfirmPassword" type="password" class="form-control" placeholder="Re-enter your password" />
                </div>
                <span asp-validation-for="Input.ConfirmPassword" class="field-error"></span>
            </div>

            <button type="submit" class="btn btn-primary btn-full">
                <i class="fas fa-user-plus"></i> Create Account
            </button>
        </form>

        <p class="auth-footer">
            Already have an account? <a href="/Account/Login">Sign in here</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
