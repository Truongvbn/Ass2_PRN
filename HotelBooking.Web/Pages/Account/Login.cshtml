@page
@model HotelBooking.Web.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Sign In";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-brand">
            <i class="fas fa-hotel"></i>
            <h1>Grand Azure</h1>
            <p>Welcome back. Please sign in to your account.</p>
        </div>

        <form method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="form-group">
                <label asp-for="Input.Email">Email Address</label>
                <div class="input-icon">
                    <i class="fas fa-envelope"></i>
                    <input asp-for="Input.Email" class="form-control" placeholder="your@email.com" autocomplete="email" />
                </div>
                <span asp-validation-for="Input.Email" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Input.Password">Password</label>
                <div class="input-icon">
                    <i class="fas fa-lock"></i>
                    <input asp-for="Input.Password" type="password" class="form-control" placeholder="••••••••" autocomplete="current-password" />
                </div>
                <span asp-validation-for="Input.Password" class="field-error"></span>
            </div>

            <div class="form-check-row">
                <label class="checkbox-label">
                    <input asp-for="Input.RememberMe" type="checkbox" />
                    <span>Remember me</span>
                </label>
            </div>

            <button type="submit" class="btn btn-primary btn-full">
                <i class="fas fa-sign-in-alt"></i> Sign In
            </button>
        </form>

        <div class="auth-divider"><span>Demo Credentials</span></div>
        <div class="demo-creds">
            <div class="demo-cred-item"><strong>Admin:</strong> admin@hotel.com / Hotel@123</div>
            <div class="demo-cred-item"><strong>Staff:</strong> staff@hotel.com / Hotel@123</div>
            <div class="demo-cred-item"><strong>Customer:</strong> customer@hotel.com / Hotel@123</div>
        </div>

        <p class="auth-footer">
            Don't have an account? <a href="/Account/Register">Register here</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
