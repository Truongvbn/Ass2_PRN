@page
@using System.Security.Claims
@model HotelBooking.Web.Pages.Rooms.DetailModel
@{
    ViewData["Title"] = Model.Room?.Name ?? "Room Detail";
}

@if (Model.Room == null)
{
    <div class="page-container">
        <div class="alert alert-danger"><i class="fas fa-exclamation-circle"></i> Room not found.</div>
        <a href="/Rooms" class="btn btn-outline"><i class="fas fa-arrow-left"></i> Back to Rooms</a>
    </div>
}
else
{
    var room = Model.Room;
    var currentUserId = User.FindFirstValue(System.Security.Claims.ClaimTypes.NameIdentifier);
    var isAdminOrStaff = User.IsInRole("Admin") || User.IsInRole("Staff");
    <div class="room-detail">
        <div class="room-detail-hero">
            <div class="room-detail-hero-carousel">
                <div class="room-detail-hero-track">
                    @{
                        var gallery = room.Gallery ?? Array.Empty<string>();
                        if (gallery.Length == 0)
                        {
                            <img src="@room.ImageUrl"
                                 alt="@room.Name"
                                 loading="lazy"
                                 onerror="this.src='/images/hotel-default.jpg'" />
                        }
                        else
                        {
                            foreach (var img in gallery)
                            {
                                <img src="@img"
                                     alt="@room.Name"
                                     loading="lazy"
                                     onerror="this.src='/images/hotel-default.jpg'" />
                            }
                        }
                    }
                </div>
            </div>
            <div class="room-detail-hero-overlay">
                <div class="room-detail-badge @(room.IsAvailable ? "badge-available" : "badge-unavailable")">
                    @(room.IsAvailable ? "Available" : "Unavailable")
                </div>
                <h1>@room.Name</h1>
                <p class="room-type-label">@room.RoomTypeName</p>
            </div>
        </div>

        <div class="react-root" style="height: 320px; margin: 18px 0;">
            <div id="hotel-location-root"
                 style="height: 100%;"
                 data-lat="@(room.HotelLatitude ?? 0)"
                 data-lng="@(room.HotelLongitude ?? 0)"
                 data-name="@room.HotelName"></div>
        </div>

        <div class="room-detail-body">
            <div class="room-detail-main">
                <div class="detail-section">
                    <h2>About this Room</h2>
                    <p>@room.Description</p>
                </div>

                <div class="detail-section">
                    <h2>Amenities</h2>
                    <div class="amenities-grid">
                        @foreach (var amenity in (room.Amenities ?? "").Split(',', System.StringSplitOptions.RemoveEmptyEntries))
                        {
                            <div class="amenity-item">
                                <i class="fas fa-check-circle"></i>
                                <span>@amenity.Trim()</span>
                            </div>
                        }
                    </div>
                </div>

                <div class="detail-section">
                    <div class="room-stats">
                        <div class="room-stat">
                            <i class="fas fa-users"></i>
                            <div>
                                <strong>Max Occupancy</strong>
                                <span>@room.MaxOccupancy guests</span>
                            </div>
                        </div>
                        <div class="room-stat">
                            <i class="fas fa-star text-gold"></i>
                            <div>
                                <strong>Rating</strong>
                                <span>@(room.AverageRating > 0 ? room.AverageRating.ToString("0.0") + $" ({room.ReviewCount} reviews)" : "No reviews yet")</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Review Section -->
                <div class="detail-section" id="reviews-section">
                    <h2>Guest Reviews</h2>
                    <div id="reviews-container">
                        @foreach (var review in Model.Reviews)
                        {
                            <div class="review-card" id="review-@review.Id">
                                <div class="review-header">
                                    <div class="review-user">
                                        <i class="fas fa-user-circle"></i>
                                        <strong>@review.UserName</strong>
                                    </div>
                                    <div class="review-rating">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            <i class="fas fa-star @(i <= review.Rating ? "text-gold" : "text-muted")"></i>
                                        }
                                    </div>
                                    <small class="review-date">@review.CreatedAt.ToString("MMM dd, yyyy")</small>
                                    @if (currentUserId != null && (review.UserName == User.Identity?.Name || isAdminOrStaff))
                                    {
                                        @if (review.UserName == User.Identity?.Name)
                                        {
                                            <button type="button" class="btn btn-sm btn-warning ml-2" title="Edit Review"
                                                    data-review-id="@review.Id"
                                                    data-review-rating="@review.Rating"
                                                    data-review-content="@review.Content"
                                                    onclick="openEditReviewModal(this)">
                                                <i class="fas fa-edit"></i>
                                            </button>
                                        }
                                        <form method="post" asp-page-handler="DeleteReview" asp-route-id="@room.Id" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this review?');">
                                            <input type="hidden" name="reviewId" value="@review.Id" />
                                            <button type="submit" class="btn btn-sm btn-danger ml-2" title="Delete Review"><i class="fas fa-trash"></i></button>
                                        </form>
                                    }
                                </div>
                                <p class="review-content">@review.Content</p>
                                <div class="review-comments">
                                    @foreach (var comment in review.Comments)
                                    {
                                        <div class="comment" id="comment-@comment.Id">
                                            <div class="d-flex justify-content-between align-items-center w-100">
                                                <div>
                                                    <i class="fas fa-reply"></i>
                                                    <strong>@comment.UserName</strong>: @comment.Content
                                                    <small>@comment.CreatedAt.ToString("MMM dd")</small>
                                                </div>
                                                @if (currentUserId != null && (comment.UserName == User.Identity?.Name || isAdminOrStaff))
                                                {
                                                    <form method="post" asp-page-handler="DeleteComment" asp-route-id="@room.Id" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this comment?');">
                                                        <input type="hidden" name="commentId" value="@comment.Id" />
                                                        <button type="submit" class="btn btn-sm text-danger" title="Delete Comment"><i class="fas fa-times"></i></button>
                                                    </form>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                                @if (User.Identity?.IsAuthenticated == true)
                                {
                                    <form method="post" asp-page-handler="AddComment" asp-route-id="@room.Id" class="comment-form">
                                        <input type="hidden" name="reviewId" value="@review.Id" />
                                        <div class="comment-input-row">
                                            <input type="text" name="content" class="form-control" placeholder="Add a comment..." required />
                                            <button type="submit" class="btn btn-sm btn-outline">Post</button>
                                        </div>
                                    </form>
                                }
                            </div>
                        }
                    </div>

                    @if (User.Identity?.IsAuthenticated == true && Model.CanReview)
                    {
                        <div class="write-review">
                            <h3>Write a Review</h3>
                            <form method="post" asp-page-handler="CreateReview">
                                <input type="hidden" name="roomId" value="@room.Id" />
                                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                                <div class="form-group">
                                    <label>Rating</label>
                                    <div class="star-rating-input">
                                        @for (int i = 5; i >= 1; i--)
                                        {
                                            <input type="radio" id="star@i" name="rating" value="@i" required />
                                            <label for="star@i"><i class="fas fa-star"></i></label>
                                        }
                                    </div>
                                </div>
                                <div class="form-group">
                                    <textarea name="content" class="form-control" rows="4"
                                              placeholder="Share your experience..." required minlength="10" maxlength="2000"></textarea>
                                </div>
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-paper-plane"></i> Submit Review
                                </button>
                            </form>
                        </div>
                    }
                </div>
            </div>

            <div class="room-detail-sidebar">
                <div class="booking-widget" id="room-availability-@room.Id">
                    <div class="booking-widget-price">
                        <span class="price-amount">$@room.PricePerNight.ToString("N0")</span>
                        <span class="price-per">per night</span>
                    </div>

                    @if (User.Identity?.IsAuthenticated == true && room.IsAvailable)
                    {
                        <a href="/Booking/Create?roomId=@room.Id" class="btn btn-primary btn-full btn-lg">
                            <i class="fas fa-calendar-plus"></i> Book Now
                        </a>
                    }
                    else if (User.Identity?.IsAuthenticated != true)
                    {
                        <a href="/Account/Login?returnUrl=/Rooms/Detail?id=@room.Id" class="btn btn-primary btn-full">
                            <i class="fas fa-sign-in-alt"></i> Login to Book
                        </a>
                    }
                    else
                    {
                        <div class="unavailable-notice">
                            <i class="fas fa-clock"></i> This room is currently unavailable
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
                    {
                        <div class="alert alert-success mt-2">@Model.SuccessMessage</div>
                    }
                    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                    {
                        <div class="alert alert-danger mt-2">@Model.ErrorMessage</div>
                    }
                </div>

                <!-- AI Chat Widget -->
                <div class="ai-chat-widget">
                    <h4><i class="fas fa-robot"></i> AI Concierge</h4>
                    <p class="text-muted" style="font-size: 0.85rem; margin-bottom: 0.75rem;">
                        You can also use the floating chat icon at the bottom right to talk to me anywhere!
                    </p>
                    <div class="form-actions">
                        <button onclick="toggleAiChat()" class="btn btn-primary btn-full">
                            <i class="fas fa-comment-dots"></i> Open AI Concierge
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- Edit Review Modal -->
<div id="edit-review-modal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:1000;">
    <div style="background:#fff; max-width:500px; margin:10% auto; padding:2rem; border-radius:8px; position:relative;">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1rem;">
            <h3 style="margin:0;"><i class="fas fa-edit"></i> Edit Your Review</h3>
            <button type="button" onclick="closeEditReviewModal()" style="background:none; border:none; font-size:1.5rem; cursor:pointer;">&times;</button>
        </div>
        <form method="post" asp-page-handler="UpdateReview" asp-route-id="@(Model.Room?.Id ?? 0)">
            <input type="hidden" id="edit-review-id" name="reviewId" />
            <div class="form-group">
                <label>Rating</label>
                <div class="star-rating-input">
                    @for (int i = 5; i >= 1; i--)
                    {
                        <input type="radio" id="edit-star@i" name="rating" value="@i" required />
                        <label for="edit-star@i"><i class="fas fa-star"></i></label>
                    }
                </div>
            </div>
            <div class="form-group">
                <textarea id="edit-review-content" name="content" class="form-control" rows="4"
                          placeholder="Update your review..." required minlength="10" maxlength="2000"></textarea>
            </div>
            <div class="form-actions">
                <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Save Changes</button>
                <button type="button" class="btn btn-outline" onclick="closeEditReviewModal()">Cancel</button>
            </div>
        </form>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/react/hotel-map.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/js/signalr-review.js"></script>
    <script type="module" src="~/react/hotel-map.js" asp-append-version="true"></script>
    <script>
    function openEditReviewModal(btn) {
        const reviewId = btn.getAttribute('data-review-id');
        const rating = btn.getAttribute('data-review-rating');
        const content = btn.getAttribute('data-review-content');
        document.getElementById('edit-review-id').value = reviewId;
        document.getElementById('edit-review-content').value = content;
        const star = document.getElementById('edit-star' + rating);
        if (star) star.checked = true;
        document.getElementById('edit-review-modal').style.display = 'block';
    }
    function closeEditReviewModal() {
        document.getElementById('edit-review-modal').style.display = 'none';
    }
    window.addEventListener('click', function(event) {
        const modal = document.getElementById('edit-review-modal');
        if (event.target === modal) closeEditReviewModal();
    });
    </script>
}
