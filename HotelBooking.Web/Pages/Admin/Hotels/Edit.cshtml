@page
@model HotelBooking.Web.Pages.Admin.Hotels.EditModel
@{
    ViewData["Title"] = "Admin — Edit Hotel";
}

<div class="page-container">
    <div class="page-header">
        <a href="/Admin/Hotels" class="back-link"><i class="fas fa-arrow-left"></i> Hotels</a>
        <h1><i class="fas fa-edit"></i> Edit Hotel</h1>
    </div>

    <div class="form-card">
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }

        <form method="post">
            <input type="hidden" asp-for="Input.Id" />

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Input.Name">Name</label>
                    <input asp-for="Input.Name" class="form-control" />
                    <span asp-validation-for="Input.Name" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Input.StarRating">Star Rating</label>
                    <input asp-for="Input.StarRating" type="number" min="1" max="5" class="form-control" />
                    <span asp-validation-for="Input.StarRating" class="field-error"></span>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Input.City">City</label>
                    <input asp-for="Input.City" class="form-control" />
                </div>
                <div class="form-group">
                    <label asp-for="Input.Address">Address</label>
                    <input asp-for="Input.Address" class="form-control" />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Input.PhoneNumber">Phone</label>
                    <input asp-for="Input.PhoneNumber" class="form-control" />
                </div>
                <div class="form-group">
                    <label asp-for="Input.Email">Email</label>
                    <input asp-for="Input.Email" class="form-control" />
                </div>
            </div>

            <div class="form-group">
                <label asp-for="Input.ImageUrl">Image URL</label>
                <input asp-for="Input.ImageUrl" class="form-control" />
            </div>

            <div class="form-group">
                <label asp-for="Input.Description">Description</label>
                <textarea asp-for="Input.Description" class="form-control" rows="4"></textarea>
            </div>

            <div class="form-group">
                <label class="checkbox-label">
                    <input asp-for="Input.IsActive" type="checkbox" />
                    <span>Hotel is Active</span>
                </label>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Update Hotel</button>
                <a href="/Admin/Hotels" class="btn btn-outline">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }

