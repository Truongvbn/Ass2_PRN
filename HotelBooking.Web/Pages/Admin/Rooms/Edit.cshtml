@page
@model HotelBooking.Web.Pages.Admin.Rooms.EditModel
@{
    ViewData["Title"] = "Admin — Edit Room";
}

<div class="page-container">
    <div class="page-header">
        <a href="/Admin/Rooms" class="back-link"><i class="fas fa-arrow-left"></i> Room Management</a>
        <h1><i class="fas fa-edit"></i> Edit Room</h1>
    </div>

    <div class="form-card">
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }

        <form method="post">
            <input type="hidden" asp-for="Input.Id" />
            @if (User.IsInRole("Admin"))
            {
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Input.HotelId">Hotel</label>
                        <select asp-for="Input.HotelId" class="form-control">
                            @foreach (var h in Model.Hotels)
                            {
                                <option value="@h.Id">@h.Name</option>
                            }
                        </select>
                        <span asp-validation-for="Input.HotelId" class="field-error"></span>
                    </div>
                </div>
            }
            else
            {
                <input type="hidden" asp-for="Input.HotelId" />
            }

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Input.Name">Room Name</label>
                    <input asp-for="Input.Name" class="form-control" />
                    <span asp-validation-for="Input.Name" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Input.RoomTypeId">Room Type</label>
                    <select asp-for="Input.RoomTypeId" class="form-control">
                        @foreach (var rt in Model.RoomTypes)
                        {
                            <option value="@rt.Id">@rt.Name</option>
                        }
                    </select>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Input.PricePerNight">Price Per Night ($)</label>
                    <input asp-for="Input.PricePerNight" type="number" class="form-control" />
                    <span asp-validation-for="Input.PricePerNight" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Input.MaxOccupancy">Max Occupancy</label>
                    <input asp-for="Input.MaxOccupancy" type="number" class="form-control" />
                    <span asp-validation-for="Input.MaxOccupancy" class="field-error"></span>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="Input.ImageUrl">Image URL</label>
                <input asp-for="Input.ImageUrl" class="form-control" />
            </div>

            <div class="form-group">
                <label asp-for="Input.Amenities">Amenities (comma-separated)</label>
                <input asp-for="Input.Amenities" class="form-control" />
            </div>

            <div class="form-group">
                <label asp-for="Input.Description">Description</label>
                <textarea asp-for="Input.Description" class="form-control" rows="4"></textarea>
            </div>

            <div class="form-group">
                <label class="checkbox-label">
                    <input asp-for="Input.IsAvailable" type="checkbox" />
                    <span>Room is Available for Booking</span>
                </label>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Update Room</button>
                <a href="/Admin/Rooms" class="btn btn-outline">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
