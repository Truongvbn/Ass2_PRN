@page
@model HotelBooking.Web.Pages.Admin.HR.Training.Programs.EditModel
@{
    ViewData["Title"] = "Admin — Edit Training Program";
}

<div class="page-container">
    <div class="page-header">
        <a href="/Admin/HR/Training/Programs?hotelId=@(Model.Input.HotelId == 0 ? (int?)null : Model.Input.HotelId)" class="back-link">
            <i class="fas fa-arrow-left"></i> Programs
        </a>
        <h1><i class="fas fa-edit"></i> Edit Training Program</h1>
    </div>

    <div class="form-card">
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }

        <form method="post">
            <input type="hidden" asp-for="Input.Id" />

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Input.Title">Title</label>
                    <input asp-for="Input.Title" class="form-control" />
                    <span asp-validation-for="Input.Title" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Input.HotelId">Scope</label>
                    <select asp-for="Input.HotelId" class="form-control">
                        <option value="0">Global</option>
                        @foreach (var h in Model.Hotels)
                        {
                            <option value="@h.Id">@h.Name</option>
                        }
                    </select>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="Input.Description">Description</label>
                <input asp-for="Input.Description" class="form-control" />
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Input.StartDate">Start</label>
                    <input asp-for="Input.StartDate" type="date" class="form-control" />
                </div>
                <div class="form-group">
                    <label asp-for="Input.EndDate">End</label>
                    <input asp-for="Input.EndDate" type="date" class="form-control" />
                </div>
            </div>

            <div class="form-group">
                <label class="checkbox-inline">
                    <input asp-for="Input.IsMandatory" type="checkbox" />
                    <span>Mandatory</span>
                </label>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Save</button>
                <a href="/Admin/HR/Training/Programs" class="btn btn-outline">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }

