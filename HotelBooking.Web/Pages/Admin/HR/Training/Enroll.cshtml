@page
@model HotelBooking.Web.Pages.Admin.HR.Training.EnrollModel
@{
    ViewData["Title"] = "Admin — Enroll Training";
}

<div class="page-container">
    <div class="page-header">
        <a href="/Admin/HR/Training/Programs?hotelId=@Model.Input.HotelId" class="back-link"><i class="fas fa-arrow-left"></i> Programs</a>
        <h1><i class="fas fa-user-plus"></i> Enroll Employee</h1>
    </div>

    @if (!string.IsNullOrEmpty(Model.Message))
    {
        <div class="alert alert-@(Model.IsError ? "danger" : "success")">@Model.Message</div>
    }

    <div class="form-card">
        <form method="post">
            <input type="hidden" asp-for="Input.TrainingProgramId" />
            <input type="hidden" asp-for="Input.HotelId" />

            <div class="form-group">
                <label>Program</label>
                <div class="form-control-plaintext">
                    @Model.Program?.Title ?? "N/A"
                </div>
            </div>

            <div class="form-group">
                <label asp-for="Input.EmployeeId">Employee</label>
                <select asp-for="Input.EmployeeId" class="form-control">
                    @foreach (var e in Model.Employees)
                    {
                        <option value="@e.Id">@e.FullName</option>
                    }
                </select>
                <span asp-validation-for="Input.EmployeeId" class="field-error"></span>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save"></i> Enroll
                </button>
                <a class="btn btn-outline" href="/Admin/HR/Training/Programs?hotelId=@Model.Input.HotelId">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }

