@page
@model HotelBooking.Web.Pages.Admin.HR.Training.ProgramsModel
@{
    ViewData["Title"] = "Admin — Training Programs";
}

<div class="page-container">
    <div class="page-header-row">
        <div class="page-header">
            <h1><i class="fas fa-chalkboard-teacher"></i> Training Programs</h1>
            <p>Create and manage training programs</p>
        </div>
    </div>

    <div class="form-card">
        <form method="get" class="filter-bar">
            <div class="form-group">
                <label for="hotelId">Hotel</label>
                <select id="hotelId" name="hotelId" class="form-control">
                    @foreach (var h in Model.Hotels)
                    {
                        if (Model.HotelId == h.Id)
                        {
                            <option value="@h.Id" selected="selected">@h.Name</option>
                        }
                        else
                        {
                            <option value="@h.Id">@h.Name</option>
                        }
                    }
                </select>
            </div>
            <button class="btn btn-outline" type="submit">
                <i class="fas fa-filter"></i> Apply
            </button>
        </form>
    </div>

    <div style="height: 16px;"></div>

    <div class="admin-table-wrapper">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Title</th>
                    <th>Range</th>
                    <th>Mandatory</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model.Programs)
                {
                    <tr>
                        <td>@p.Id</td>
                        <td>@p.Title</td>
                        <td>@p.StartDate.ToString("yyyy-MM-dd") - @p.EndDate.ToString("yyyy-MM-dd")</td>
                        <td>@(p.IsMandatory ? "Yes" : "No")</td>
                        <td>
                            <a class="btn btn-sm btn-outline" href="/Admin/HR/Training/Programs/Edit?id=@p.Id&hotelId=@Model.HotelId">
                                <i class="fas fa-edit"></i>
                            </a>
                            <a class="btn btn-sm btn-primary" href="/Admin/HR/Training/Enroll?programId=@p.Id&hotelId=@Model.HotelId" style="margin-left: 8px;">
                                <i class="fas fa-user-plus"></i>
                            </a>
                        </td>
                    </tr>
                }
                @if (Model.Programs.Count == 0)
                {
                    <tr>
                        <td colspan="5" class="text-muted">No training programs.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div style="height: 16px;"></div>

    <div class="form-card">
        <h3>Create training program</h3>
        <form method="post">
            <input type="hidden" asp-for="Input.HotelId" />
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Input.Title">Title</label>
                    <input asp-for="Input.Title" class="form-control" />
                </div>
            </div>
            <div class="form-group">
                <label asp-for="Input.Description">Description</label>
                <input asp-for="Input.Description" class="form-control" />
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Input.StartDate">Start</label>
                    <input asp-for="Input.StartDate" type="date" class="form-control" />
                </div>
                <div class="form-group">
                    <label asp-for="Input.EndDate">End</label>
                    <input asp-for="Input.EndDate" type="date" class="form-control" />
                </div>
            </div>
            <div class="form-group">
                <label class="checkbox-inline">
                    <input asp-for="Input.IsMandatory" type="checkbox" />
                    <span>Mandatory</span>
                </label>
            </div>
            <div class="form-actions">
                <button type="submit" asp-page-handler="Create" class="btn btn-primary">
                    <i class="fas fa-save"></i> Create
                </button>
            </div>
        </form>
    </div>
</div>

