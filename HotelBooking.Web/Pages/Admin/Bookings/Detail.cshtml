@page
@model HotelBooking.Web.Pages.Admin.Bookings.DetailModel
@{
    ViewData["Title"] = "Manage — Booking Details";
}

<div class="page-container">
    <div class="page-header">
        <a href="/Admin/Bookings" class="back-link"><i class="fas fa-arrow-left"></i> Bookings Management</a>
        <h1><i class="fas fa-file-contract"></i> Booking Details</h1>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
        <a href="/Admin/Bookings" class="btn btn-outline">Back to Bookings</a>
    }
    else if (Model.Booking != null)
    {
        <div class="form-card">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem;">
                <h2 style="margin:0;">Booking #@Model.Booking.Id</h2>
                <span class="badge badge-@Model.Booking.Status.ToLower()">@Model.Booking.Status</span>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="detail-label">Customer</label>
                    <div class="detail-value">@Model.Booking.UserName</div>
                </div>
                <div class="form-group">
                    <label class="detail-label">User ID</label>
                    <div class="detail-value"><small>@Model.Booking.UserId</small></div>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="detail-label">Room</label>
                    <div class="detail-value">@Model.Booking.RoomName</div>
                </div>
                <div class="form-group">
                    <label class="detail-label">Room Type</label>
                    <div class="detail-value">@Model.Booking.RoomTypeName</div>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="detail-label">Check-In</label>
                    <div class="detail-value">@Model.Booking.CheckIn.ToString("dddd, MMMM dd, yyyy")</div>
                </div>
                <div class="form-group">
                    <label class="detail-label">Check-Out</label>
                    <div class="detail-value">@Model.Booking.CheckOut.ToString("dddd, MMMM dd, yyyy")</div>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="detail-label">Number of Nights</label>
                    <div class="detail-value">@((Model.Booking.CheckOut - Model.Booking.CheckIn).Days)</div>
                </div>
                <div class="form-group">
                    <label class="detail-label">Guests</label>
                    <div class="detail-value">@Model.Booking.NumberOfGuests</div>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="detail-label">Total Price</label>
                    <div class="detail-value"><strong>$@Model.Booking.TotalPrice.ToString("N2")</strong></div>
                </div>
                <div class="form-group">
                    <label class="detail-label">Booked On</label>
                    <div class="detail-value">@Model.Booking.CreatedAt.ToString("MMMM dd, yyyy HH:mm")</div>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.Booking.GuestNotes))
            {
                <div class="form-row">
                    <label class="detail-label">Guest Notes</label>
                    <div class="detail-value">@Model.Booking.GuestNotes</div>
                </div>
            }
            @if (!string.IsNullOrEmpty(Model.Booking.CancellationReason))
            {
                <div class="form-row">
                    <label class="detail-label">Cancellation / Rejection Reason</label>
                    <div class="detail-value text-danger">@Model.Booking.CancellationReason</div>
                </div>
            }
            @if (Model.Booking.PaymentDeadline.HasValue)
            {
                <div class="form-row">
                    <label class="detail-label">Payment Deadline</label>
                    <div class="detail-value">@Model.Booking.PaymentDeadline.Value.ToString("MMMM dd, yyyy HH:mm")</div>
                </div>
            }

            <div class="form-actions mt-3">
                @if (Model.Booking.Status == "Pending")
                {
                    <form method="post" asp-page-handler="Approve" asp-route-id="@Model.Booking.Id" class="d-inline">
                        <button class="btn btn-success"><i class="fas fa-check"></i> Approve</button>
                    </form>
                    <form method="post" asp-page-handler="Reject" asp-route-id="@Model.Booking.Id" class="d-inline">
                        <input type="text" name="RejectReason" placeholder="Reason" class="form-control d-inline-block" style="width:150px;" />
                        <button class="btn btn-warning"><i class="fas fa-times"></i> Reject</button>
                    </form>
                }
                @if (Model.Booking.Status == "Confirmed")
                {
                    <form method="post" asp-page-handler="CheckIn" asp-route-id="@Model.Booking.Id" class="d-inline">
                        <button class="btn btn-success"><i class="fas fa-door-open"></i> Check-in</button>
                    </form>
                    <form method="post" asp-page-handler="NoShow" asp-route-id="@Model.Booking.Id" class="d-inline">
                        <button class="btn btn-warning"><i class="fas fa-user-times"></i> No-show</button>
                    </form>
                }
                @if (Model.Booking.Status == "CheckedIn")
                {
                    <button type="button" class="btn btn-primary" onclick="document.getElementById('checkout-modal').style.display='block'">
                        <i class="fas fa-flag-checkered"></i> Process Check-out
                    </button>
                }
                @if (new[] { "Pending", "AwaitingPayment", "Confirmed" }.Contains(Model.Booking.Status))
                {
                    <form method="post" asp-page-handler="Cancel" asp-route-id="@Model.Booking.Id" class="d-inline" onsubmit="return confirm('Cancel this booking?')">
                        <input type="text" name="RejectReason" placeholder="Cancellation reason" class="form-control d-inline-block" style="width:180px;" required />
                        <button class="btn btn-danger"><i class="fas fa-times"></i> Cancel</button>
                    </form>
                }
                @if (Model.Booking.Status == "AwaitingExtraPayment")
                {
                    <span class="text-warning small"><i class="fas fa-exclamation-triangle"></i> Awaiting guest payment for extra charges</span>
                }
                <a href="/Admin/Bookings" class="btn btn-outline"><i class="fas fa-arrow-left"></i> Back to List</a>
            </div>
        </div>
    }
</div>

@if (Model.Booking?.Status == "CheckedIn")
{
    <div id="checkout-modal" class="modal-backdrop" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:1000; overflow-y:auto;">
        <div class="modal-container" style="background:#fff; max-width:600px; margin:5% auto; padding:2rem; border-radius:var(--radius-lg); position:relative; box-shadow:var(--shadow-lg);\ cartoons-container">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem; border-bottom:1px solid var(--border); padding-bottom:1rem;">
                <h3 style="margin:0;"><i class="fas fa-sign-out-alt"></i> Guest Check-out</h3>
                <button type="button" onclick="document.getElementById('checkout-modal').style.display='none'" style="background:none; border:none; font-size:1.5rem; cursor:pointer;">&times;</button>
            </div>

            <form method="post" asp-page-handler="Complete" asp-route-id="@Model.Booking.Id">
                <div class="form-section">
                    <h4 style="margin-bottom:1rem; color:var(--navy);"><i class="fas fa-receipt"></i> Additional Charges</h4>
                    <div class="form-group">
                        <label asp-for="CheckoutDto.ExtraChargeDescription">Description (Food, drinks, etc.)</label>
                        <textarea asp-for="CheckoutDto.ExtraChargeDescription" class="form-control" rows="2" placeholder="e.g. 2x Minibar water, 1x Extra breakfast"></textarea>
                    </div>
                    <div class="form-group">
                        <label asp-for="CheckoutDto.ExtraChargeAmount">Amount ($)</label>
                        <input asp-for="CheckoutDto.ExtraChargeAmount" type="number" step="0.01" min="0" class="form-control" value="0" />
                    </div>
                </div>

                <div class="form-section mt-4">
                    <h4 style="margin-bottom:1rem; color:var(--navy);"><i class="fas fa-box-open"></i> Lost & Found</h4>
                    <div class="form-group">
                        <label asp-for="CheckoutDto.LostAndFoundNotes">Items Found in Room</label>
                        <textarea asp-for="CheckoutDto.LostAndFoundNotes" class="form-control" rows="2" placeholder="Describe any items left behind by the guest..."></textarea>
                    </div>
                    <div class="form-group">
                        <label asp-for="CheckoutDto.LostAndFoundImageUrl">Evidence Image URL</label>
                        <input asp-for="CheckoutDto.LostAndFoundImageUrl" class="form-control" placeholder="https://..." />
                        <small class="text-muted">Link to a photo of the items found.</small>
                    </div>
                </div>

                <div style="margin-top:2rem; padding-top:1rem; border-top:1px solid var(--border); display:flex; justify-content:flex-end; gap:1rem;">
                    <button type="button" class="btn btn-outline" onclick="document.getElementById('checkout-modal').style.display='none'">Cancel</button>
                    <button type="submit" class="btn btn-primary"><i class="fas fa-check-circle"></i> Confirm Check-out</button>
                </div>
            </form>
        </div>
    </div>
}

@section Scripts {
}
