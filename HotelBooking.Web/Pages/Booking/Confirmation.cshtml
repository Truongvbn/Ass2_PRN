@page
@model HotelBooking.Web.Pages.Booking.ConfirmationModel
@{
    ViewData["Title"] = "Booking Confirmed";
    var successMessage = TempData["SuccessMessage"]?.ToString();
    var errorMessage = TempData["ErrorMessage"]?.ToString();
}

<div class="page-container confirmation-page">
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }
    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert alert-success">@successMessage</div>
    }
    @if (Model.Booking != null)
    {
        <div class="confirmation-card">
            @if (Model.Booking.Status == "AwaitingPayment")
            {
                <div class="confirmation-icon text-success"><i class="fas fa-check-circle"></i></div>
                <h1>Booking Submitted! Complete Payment</h1>
                <p class="confirmation-subtitle">Your booking is reserved for 24 hours. Please pay to confirm your stay.</p>
            }
            else if (Model.Booking.Status == "Confirmed" || Model.Booking.Status == "CheckedIn")
            {
                <div class="confirmation-icon"><i class="fas fa-check-circle"></i></div>
                <h1>Booking Confirmed!</h1>
                <p class="confirmation-subtitle">All set! See you on @Model.Booking.CheckIn.ToString("MMMM dd, yyyy").</p>
            }
            else if (Model.Booking.Status == "Rejected")
            {
                <div class="confirmation-icon text-danger"><i class="fas fa-times-circle"></i></div>
                <h1>Booking Declined</h1>
                <p class="confirmation-subtitle">Unfortunately your request was declined. @(string.IsNullOrEmpty(Model.Booking.CancellationReason) ? "" : "Reason: " + Model.Booking.CancellationReason)</p>
            }
            else if (Model.Booking.Status == "Expired")
            {
                <div class="confirmation-icon text-muted"><i class="fas fa-clock"></i></div>
                <h1>Booking Expired</h1>
                <p class="confirmation-subtitle">This booking has expired. Please make a new reservation.</p>
            }
            else if (Model.Booking.Status == "Cancelled")
            {
                <div class="confirmation-icon text-danger"><i class="fas fa-times-circle"></i></div>
                <h1>Booking Cancelled</h1>
                <p class="confirmation-subtitle">This booking has been cancelled.</p>
            }
            else
            {
                <div class="confirmation-icon"><i class="fas fa-check-circle"></i></div>
                <h1>Booking @Model.Booking.Status</h1>
                <p class="confirmation-subtitle">Your reservation status.</p>
            }

            <div class="booking-summary">
                <div class="summary-row">
                    <span class="label">Room</span>
                    <span class="value">@Model.Booking.RoomName</span>
                </div>
                <div class="summary-row">
                    <span class="label">Check-In</span>
                    <span class="value">@Model.Booking.CheckIn.ToString("MMMM dd, yyyy")</span>
                </div>
                <div class="summary-row">
                    <span class="label">Check-Out</span>
                    <span class="value">@Model.Booking.CheckOut.ToString("MMMM dd, yyyy")</span>
                </div>
                <div class="summary-row">
                    <span class="label">Guests</span>
                    <span class="value">@Model.Booking.NumberOfGuests</span>
                </div>
                <div class="summary-row highlight">
                    <span class="label">Total</span>
                    <span class="value">$@Model.Booking.TotalPrice.ToString("N2")</span>
                </div>
                <div class="summary-row">
                    <span class="label">Status</span>
                    <span class="value"><span class="badge badge-@Model.Booking.Status.ToLower()">@Model.Booking.Status</span></span>
                </div>
            </div>

            <div class="confirmation-actions">
                @if (Model.Booking.Status == "AwaitingPayment")
                {
                    <a href="/Booking/Payment?id=@Model.Booking.Id" class="btn btn-success">
                        <i class="fas fa-credit-card"></i> Pay Now
                    </a>
                }
                <a href="/Booking/MyBookings" class="btn btn-primary">
                    <i class="fas fa-list"></i> View My Bookings
                </a>
                <a href="/Rooms" class="btn btn-outline">
                    <i class="fas fa-bed"></i> Browse More Rooms
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-danger">Booking not found.</div>
        <a href="/Booking/MyBookings" class="btn btn-outline">My Bookings</a>
    }
</div>
