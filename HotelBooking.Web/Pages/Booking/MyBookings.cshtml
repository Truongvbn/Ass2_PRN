@page
@model HotelBooking.Web.Pages.Booking.MyBookingsModel
@{
    ViewData["Title"] = "My Bookings";
}

<div class="page-container">
    <div class="page-header">
        <h1><i class="fas fa-calendar-check"></i> My Bookings</h1>
        <p>Manage your reservations</p>
    </div>

    @if (!string.IsNullOrEmpty(Model.Message))
    {
        <div class="alert alert-@(Model.IsError ? "danger" : "success")">@Model.Message</div>
    }

    @if (!Model.Bookings.Any())
    {
        <div class="empty-state">
            <i class="fas fa-calendar-times"></i>
            <p>You have no bookings yet.</p>
            <a href="/Rooms" class="btn btn-primary">Explore Rooms</a>
        </div>
    }
    else
    {
        <div class="bookings-list">
            @foreach (var booking in Model.Bookings)
            {
                <div class="booking-card" id="booking-@booking.Id">
                    <div class="booking-card-header">
                        <div>
                            <h3>@booking.RoomName</h3>
                            <span class="room-type-label">@booking.RoomTypeName</span>
                        </div>
                        <span class="badge badge-@booking.Status.ToLower()">@booking.Status</span>
                    </div>
                    <div class="booking-card-body">
                        <div class="booking-dates">
                            <div class="date-item">
                                <i class="fas fa-plane-arrival text-gold"></i>
                                <div>
                                    <small>Check-In</small>
                                    <strong>@booking.CheckIn.ToString("MMM dd, yyyy")</strong>
                                </div>
                            </div>
                            <div class="date-arrow"><i class="fas fa-long-arrow-alt-right"></i></div>
                            <div class="date-item">
                                <i class="fas fa-plane-departure text-gold"></i>
                                <div>
                                    <small>Check-Out</small>
                                    <strong>@booking.CheckOut.ToString("MMM dd, yyyy")</strong>
                                </div>
                            </div>
                        </div>
                        <div class="booking-meta">
                            <span><i class="fas fa-users"></i> @booking.NumberOfGuests guests</span>
                            <span class="booking-price">$@booking.TotalPrice.ToString("N2")</span>
                        </div>
                    </div>
                    <div class="booking-card-footer">
                        @if (booking.Status == "AwaitingPayment")
                        {
                            <a href="/Booking/Payment?id=@booking.Id" class="btn btn-sm btn-success">
                                <i class="fas fa-credit-card"></i> Pay Now
                            </a>
                            <button type="button" class="btn btn-sm btn-danger" onclick="openCancelModal(@booking.Id)">
                                <i class="fas fa-times"></i> Cancel
                            </button>
                        }
                        @if (booking.Status == "Pending")
                        {
                            <button type="button" class="btn btn-sm btn-danger" onclick="openCancelModal(@booking.Id)">
                                <i class="fas fa-times"></i> Cancel
                            </button>
                        }
                        @if (booking.Status == "Confirmed")
                        {
                            <button type="button" class="btn btn-sm btn-danger" onclick="openCancelModal(@booking.Id)">
                                <i class="fas fa-times"></i> Cancel
                            </button>
                        }
                        @if (booking.Status == "AwaitingExtraPayment")
                        {
                            <span class="text-warning small"><i class="fas fa-exclamation-triangle"></i> Awaiting extra payment</span>
                        }
                        @if (booking.RefundedAt.HasValue && booking.RefundAmount > 0)
                        {
                            <span class="text-success small"><i class="fas fa-undo"></i> Refund $@((booking.RefundAmount ?? 0).ToString("N2")) on @booking.RefundedAt!.Value.ToString("MMM dd")</span>
                        }
                        <div class="completed-info mt-2 mb-2 p-2 rounded bg-light border">
                            @if (booking.ExtraChargeAmount > 0)
                            {
                                <div class="text-danger small">
                                    <strong><i class="fas fa-exclamation-circle"></i> Extra Charges:</strong> $@booking.ExtraChargeAmount.ToString("N2") (@booking.ExtraChargeDescription)
                                    @if (!booking.IsExtraChargePaid)
                                    {
                                        <a href="/Booking/Payment?id=@booking.Id&extra=true" class="btn btn-xs btn-outline-danger ml-2">Pay Now</a>
                                    }
                                    else
                                    {
                                        <span class="badge badge-success ml-2">Paid</span>
                                    }
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(booking.LostAndFoundNotes))
                            {
                                <div class="text-warning small mt-1">
                                    <strong><i class="fas fa-box-open"></i> Lost & Found:</strong> @booking.LostAndFoundNotes
                                    @if (!string.IsNullOrEmpty(booking.LostAndFoundImageUrl))
                                    {
                                        <a href="@booking.LostAndFoundImageUrl" target="_blank" class="ml-1"><i class="fas fa-image"></i> View Photo</a>
                                    }
                                </div>
                            }
                        </div>
                        @if (booking.Status == "Completed")
                        {
                            <a href="/Rooms/Detail?id=@booking.RoomId#reviews-section" class="btn btn-sm btn-outline">
                                <i class="fas fa-star"></i> Write Review
                            </a>
                        }
                        <small class="booking-id">Booking #@booking.Id • Booked @booking.CreatedAt.ToString("MMM dd")</small>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <script src="~/js/signalr-booking.js"></script>
    <script>
        function openCancelModal(bookingId) {
            document.getElementById('cancel-booking-id').value = bookingId;
            document.getElementById('cancel-reason').value = '';
            document.getElementById('cancel-modal').style.display = 'block';
            setTimeout(() => document.getElementById('cancel-reason').focus(), 50);
        }
        function closeCancelModal() {
            document.getElementById('cancel-modal').style.display = 'none';
        }
    </script>
}

<div id="cancel-modal" class="modal-backdrop" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:1000; overflow-y:auto;">
    <div class="modal-container" style="background:#fff; max-width:600px; margin:5% auto; padding:2rem; border-radius:var(--radius-lg); position:relative; box-shadow:var(--shadow-lg);">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem; border-bottom:1px solid var(--border); padding-bottom:1rem;">
            <h3 style="margin:0;"><i class="fas fa-times-circle"></i> Cancel Booking</h3>
            <button type="button" onclick="closeCancelModal()" style="background:none; border:none; font-size:1.5rem; cursor:pointer;">&times;</button>
        </div>
        <form method="post" asp-page-handler="Cancel">
            <input type="hidden" name="bookingId" id="cancel-booking-id" value="" />
            <div class="form-group">
                <label for="cancel-reason">Reason</label>
                <textarea id="cancel-reason" name="cancelReason" class="form-control" rows="3" placeholder="Please provide a reason for cancellation..." required></textarea>
            </div>
            <div style="margin-top:1rem;" class="text-muted small">
                Same-day cancellation (on check-in day) refunds 50%. Earlier cancellations refund 100%.
            </div>
            <div style="margin-top:2rem; display:flex; justify-content:flex-end; gap:1rem;">
                <button type="button" class="btn btn-outline" onclick="closeCancelModal()">Close</button>
                <button type="submit" class="btn btn-danger"><i class="fas fa-times"></i> Confirm Cancel</button>
            </div>
        </form>
    </div>
</div>
