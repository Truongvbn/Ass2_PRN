{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=...;Port=...;Database=...;Username=...;Password=...;SSL Mode=Require;Trust Server Certificate=true"
  },
  "Supabase": {
    "Url": "https://<project-ref>.supabase.co",
    "Key": "<anon-key>"
  },
  "AiAssistant": {
    "Provider": "Gemini",
    "GeminiApiKey": "<api-key>"
  }
}
